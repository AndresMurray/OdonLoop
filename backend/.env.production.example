# ===== CONFIGURACIÓN PARA PRODUCCIÓN =====
# Copia este archivo como .env.production y configura las variables reales

# ===== DJANGO CORE SETTINGS =====  
# Genera un SECRET_KEY único en: https://djecrety.ir/
SECRET_KEY=your-super-secret-production-key-change-this

# DEBUG debe ser False en producción
DEBUG=False

# ALLOWED_HOSTS: dominios de producción separados por comas (sin espacios)
# Ejemplo: ALLOWED_HOSTS=tu-app.up.railway.app,api.tudominio.com
ALLOWED_HOSTS=tu-app.up.railway.app

# ===== DATABASE CONFIGURATION =====
# Railway configura esto automáticamente
# Si usas otro servicio, obtén la URL de conexión PostgreSQL
DATABASE_URL=postgresql://user:password@host:port/dbname

# ===== CORS CONFIGURATION =====
# URLs del frontend en producción (separadas por comas, sin espacios)
# Ejemplo: CORS_ALLOWED_ORIGINS=https://tu-frontend.vercel.app,https://tudominio.com
CORS_ALLOWED_ORIGINS=https://tu-frontend.vercel.app

# ===== CLOUDINARY CONFIGURATION =====
CLOUDINARY_CLOUD_NAME=tu_cloud_name_produccion
CLOUDINARY_API_KEY=tu_api_key_produccion
CLOUDINARY_API_SECRET=tu_api_secret_produccion

# ===== EMAIL CONFIGURATION =====
# PRODUCCIÓN: SendGrid API (OBLIGATORIO para Railway)
# Railway bloquea puertos SMTP, usa la API en su lugar
SENDGRID_API_KEY=TU_API_KEY_DE_SENDGRID_PRODUCCION
DEFAULT_FROM_EMAIL=noreply@tudominio.com

# ⚠️ IMPORTANTE: 
# 1. El email en DEFAULT_FROM_EMAIL debe estar verificado en SendGrid
# 2. La API Key necesita permisos de "Mail Send"
# 3. NO uses SMTP en Railway (puertos bloqueados)
# 4. Ver guía completa en: CONFIGURACION_EMAIL_RAILWAY.md


