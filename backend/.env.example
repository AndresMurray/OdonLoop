# Variables de entorno - NO SUBIR A GIT
# Copia este archivo como .env y completa con tus credenciales reales

# ===== DJANGO CORE SETTINGS =====
# Genera un SECRET_KEY seguro en: https://djecrety.ir/
SECRET_KEY=your-super-secret-key-change-this-in-production

# DEBUG: True para desarrollo, False para producción
DEBUG=True

# ALLOWED_HOSTS: dominios separados por comas (sin espacios)
# Ejemplo para producción: ALLOWED_HOSTS=tu-app.up.railway.app,tudominio.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ===== DATABASE CONFIGURATION =====
# En desarrollo: dejar vacío para usar SQLite
# En Railway: se configura automáticamente con la variable DATABASE_URL
# DATABASE_URL=postgresql://user:password@host:port/dbname

# ===== CORS CONFIGURATION =====
# URLs del frontend permitidas (separadas por comas, sin espacios)
# Ejemplo: CORS_ALLOWED_ORIGINS=https://tu-frontend.vercel.app,https://tudominio.com
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ===== CLOUDINARY CONFIGURATION =====
# Get these values from your Cloudinary dashboard: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# ===== EMAIL CONFIGURATION =====
# DESARROLLO: Emails en consola (no se envían realmente)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=sistemagestionodontologico@gmail.com

# Para pruebas con SendGrid API (RECOMENDADO):
# Descomenta y configura tu API Key
# SENDGRID_API_KEY=TU_API_KEY_DE_SENDGRID_AQUI

# Alternativa SMTP (solo para local, no funciona en Railway):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=TU_API_KEY_DE_SENDGRID_AQUI

# EMAIL_HOST_PASSWORD=TU_SMTP_PASSWORD
# DEFAULT_FROM_EMAIL=verificado@tudominio.com
